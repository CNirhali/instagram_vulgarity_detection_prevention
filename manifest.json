{
  "manifest_version": 3,
  "name": "Social Guard: Vulgarity & Profanity Filter",
  "version": "1.0.0",
  "description": "Redacts and blurs vulgarity, profanity, hate speech, and harassment on Instagram and YouTube with a plug-and-play architecture.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "core/detector.js",
        "core/social-adapter.js",
        "adapters/instagram.js",
        "adapters/youtube.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
